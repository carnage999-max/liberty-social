# Stripe Publishable Key (required for PaymentSheet)
# Get this from: https://dashboard.stripe.com/apikeys (use test key for development)
# Must be prefixed with EXPO_PUBLIC_ to be available in the app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# API base URL used by the app for REST and derived WebSocket connections.
# This should include the `/api` suffix because sockets are derived from it by
# swapping the scheme and removing the trailing `/api`.
# Examples:
#   Production: EXPO_PUBLIC_API_BASE_URL=https://api.mylibertysocial.com/api
#   Local dev:  EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Optional explicit WebSocket base if sockets are served from a different host.
# Examples:
#   EXPO_PUBLIC_WS_BASE_URL=wss://notifications.mylibertysocial.com
#   EXPO_PUBLIC_WS_BASE_URL=ws://192.168.1.100:8000

# WebRTC ICE server settings for voice/video calls.
# STUN can discover candidates, but TURN is usually required for reliable
# audio/video across mobile networks and carrier NAT.
# Comma-separated STUN URLs (optional; defaults to Google STUN if omitted).
EXPO_PUBLIC_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302

# TURN server (recommended for production call reliability)
# Example URL:
#   turn:turn.mylibertysocial.com:3478?transport=udp
#   turns:turn.mylibertysocial.com:5349?transport=tcp
EXPO_PUBLIC_WEBRTC_TURN_URL=
EXPO_PUBLIC_WEBRTC_TURN_USERNAME=
EXPO_PUBLIC_WEBRTC_TURN_CREDENTIAL=
